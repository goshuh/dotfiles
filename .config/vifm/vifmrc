colorscheme onedark

command link ln -s %f:p %D
command nvim nvim  %f

set fastrun
set fusehome=/tmp/mnt
set history=100
set ignorecase
set incsearch
set nohlsearch
set norunexec
set scrolloff=1
set slowfs=curlftpfs
set smartcase
set sortnumbers
set statusline=" %A %5u:%-5g %15d"
set timefmt=%Y-%m-%d/%H:%M
set trash
set trashdir=/tmp
set undolevels=100
set vicmd="nvim --noplugin --cmd 'runtime plugin/gzip.vim'"
set vifminfo=chistory,dhistory,phistory,shistory
set wildmenu

map <f2>     cw<c-u>
map <f10>   :mkdir<space>
map <s-f10> :touch<space>
map  E      :empty<cr>
map  C      :copy!<cr>
map  X      :move!<cr>
map  D      :delete!<cr>
map  S      :sort<cr>
map  L      :link<cr>
map  V      :nvim<cr>
map ;q      :quit<cr>
